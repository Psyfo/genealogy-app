# Copy to .env.local and fill in. Never commit real secrets.

# Neo4j connection.
# Single local instance (Neo4j Desktop / Docker): use bolt://
# Aura / clustered: use neo4j+s://<host>
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Auth — secret used to sign session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=replace-with-a-long-random-string
